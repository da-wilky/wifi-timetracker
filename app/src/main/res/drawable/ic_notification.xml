<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Clock face ring -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:pathData="M12,2 A8,8 0 1,1 11.99,2 Z"/>

    <!-- Clock hour hand (pointing ~10 o'clock) -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M12,10 L10,7"/>

    <!-- Clock minute hand (pointing ~2 o'clock) -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M12,10 L15.5,8"/>

    <!-- WiFi dot -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M12,22 A1,1 0 1,1 11.99,22 Z"/>

    <!-- WiFi arc small -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M9.5,19.5 A3.5,3.5 0 0,1 14.5,19.5"/>

    <!-- WiFi arc large -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M7,17 A7,7 0 0,1 17,17"/>

