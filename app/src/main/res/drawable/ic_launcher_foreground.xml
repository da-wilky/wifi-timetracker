        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M86,54 L82,54"/>

    <!-- Clock tick at 6 o'clock -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M54,86 L54,82"/>

    <!-- Clock tick at 9 o'clock -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M22,54 L26,54"/>

    <!-- WiFi dot (inside clock at top, at 12 o'clock area) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,38 A2.5,2.5 0 1,1 53.99,38 Z"/>

    <!-- WiFi arc - innermost -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M48,33 A8.5,8.5 0 0,1 60,33"/>

    <!-- WiFi arc - middle -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:fillColor="#00000000"
