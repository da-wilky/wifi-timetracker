        android:strokeLineCap="round"
        android:pathData="M39,23 A20.5,20.5 0 0,1 69,23"/>

    <!-- Clock hour hand (pointing toward ~10 o'clock) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M54,54 L43,44"/>

    <!-- Clock minute hand (pointing toward ~2 o'clock) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M54,54 L64,43"/>

    <!-- Clock second hand / tail (pointing straight down) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M54,54 L54,74"/>

    <!-- Center pivot of clock -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,54 A3,3 0 1,1 53.99,54 Z"/>

